---
import Giscus from "../components/misc/Giscus.astro";
import { Icon } from "astro-icon/components";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { linksConfig } from "../config";

const { friends, siteInfo, apply } = linksConfig;
---

<MainGridLayout title="Links" description="友情链接">
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">

            <!-- Friend Links -->
            <h2 class="dark:text-neutral-200 font-bold text-neutral-700 mb-4 text-xl">友情链接</h2>
            <div class="gap-x-6 gap-y-8 grid grid-cols-1 my-4 sm:grid-cols-2">
                {friends.map((friend) => (
                    <a
                        href={friend.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="group flex flex-nowrap items-stretch gap-5 h-24 rounded-[var(--radius-large)] transition active:scale-[0.99] hover:bg-[var(--btn-plain-bg-hover)]"
                    >
                        <div class="relative w-24 h-24 rounded-lg overflow-hidden flex-shrink-0 bg-zinc-200 dark:bg-zinc-800 flex items-center justify-center">
                            <span class="absolute inset-0 flex items-center justify-center text-3xl text-zinc-300 dark:text-zinc-600 animate-pulse">{friend.name.charAt(0)}</span>
                            <img
                                src={friend.avatar}
                                alt={friend.name}
                                class="w-full h-full object-cover opacity-0 transition-opacity duration-300"
                                loading="lazy"
                                onload="this.style.opacity='1';this.previousElementSibling?.classList.remove('animate-pulse')"
                                onerror="this.style.display='none'"
                            />
                        </div>
                        <div class="flex justify-center flex-col gap-1 grow w-full min-w-0">
                            <div class="font-bold text-75 transition group-hover:text-[var(--primary)]">{friend.name}</div>
                            <div class="text-sm text-50 font-medium mb-1">{friend.description}</div>
                        </div>
                        <div class="btn-regular w-16 flex items-center justify-center rounded-lg transition active:scale-95 flex-shrink-0">
                            <Icon name="material-symbols:chevron-right-rounded" class="text-3xl text-[var(--primary)] mx-auto" />
                        </div>
                    </a>
                ))}
            </div>

            <!-- Divider -->
            <div class="border-t border-black/5 dark:border-white/10 my-8"></div>

            <!-- Site Info -->
            <h2 class="dark:text-neutral-200 font-bold text-neutral-700 mb-4 text-xl">本站信息</h2>
            <div class="text-sm text-50 mb-3">点击下方信息即可复制</div>
            <div
                id="site-info-block"
                class="rounded-lg p-4 mb-6 text-sm font-mono cursor-pointer transition hover:opacity-80 active:scale-[0.99]"
                style="background: var(--btn-regular-bg);"
            >
                <div class="mb-1">Name: {siteInfo.name}</div>
                <div class="mb-1">Desc: {siteInfo.desc}</div>
                <div class="mb-1">Link: {siteInfo.link}</div>
                <div>Avatar: {siteInfo.avatar}</div>
            </div>

            <!-- Apply Requirements -->
            <h2 class="dark:text-neutral-200 font-bold text-neutral-700 mb-4 text-xl">申请友链</h2>
            <div class="text-sm text-50 mb-4 space-y-2">
                <p>{apply.text}</p>
                {apply.list && (
                    <ul class="list-disc list-inside space-y-1 ml-2">
                        {apply.list.map((item) => (
                            <li>{item}</li>
                        ))}
                    </ul>
                )}
                {apply.footer && <p class="mt-3">{apply.footer}</p>}
            </div>

            <!-- Comments -->
            <Giscus />
        </div>
    </div>

    <script is:inline>
    if (!window.__siteInfoCopyBound) {
        window.__siteInfoCopyBound = true;
        function copyToClipboard(text) {
            if (navigator.clipboard && window.isSecureContext) {
                return navigator.clipboard.writeText(text);
            }
            return new Promise(function(resolve, reject) {
                var textarea = document.createElement("textarea");
                textarea.value = text;
                textarea.style.position = "fixed";
                textarea.style.opacity = "0";
                document.body.appendChild(textarea);
                textarea.focus();
                textarea.select();
                try {
                    document.execCommand("copy");
                    resolve();
                } catch (e) {
                    reject(e);
                } finally {
                    document.body.removeChild(textarea);
                }
            });
        }
        document.addEventListener("click", function(e) {
            var infoBlock = document.getElementById("site-info-block");
            if (!infoBlock) return;
            if (!infoBlock.contains(e.target)) return;
            var text = infoBlock.innerText;
            copyToClipboard(text).then(function() {
                infoBlock.style.background = "var(--btn-regular-bg-active)";
                setTimeout(function() {
                    infoBlock.style.background = "var(--btn-regular-bg)";
                }, 500);
            }).catch(function(e) {
                console.error("Copy failed:", e);
            });
        });
    }
    </script>
</MainGridLayout>
